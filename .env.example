# Database
POSTGRES_USER=anima
POSTGRES_PASSWORD=anima_secret_123
POSTGRES_DB=anima_studio
DATABASE_URL=postgresql+asyncpg://anima:anima_secret_123@postgres:5432/anima_studio

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage
OUTPUTS_DIR=/app/outputs

# Environment
ENVIRONMENT=development

# LLM Provider Configuration
LLM_PROVIDER=openai  # Options: gemini, openai

# Gemini LLM Configuration (if using Gemini)
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash-exp
LLM_TEMPERATURE=0.2

# OpenAI-compatible LLM Configuration (Local or Paid)
# For local Ollama: Use http://host.docker.internal:11434/v1
# For local LM Studio: Use http://host.docker.internal:1234/v1
# For paid OpenAI: Use https://api.openai.com/v1
OPENAI_API_KEY=sk-placeholder-if-local
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_MODEL=llama3.1

